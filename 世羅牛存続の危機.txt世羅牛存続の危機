<script>
(function ($) {

var MWLIBclip = MWLIBclip || {};

MWLIBclip.guest = (function () {
  const init = function () {
    openGuestFlag();
  };
  var $addClip = $('.js-addclip');
  const openGuestFlag = function(){
    $addClip.on('click',function(){
      $('.js-clip-guest-flag').css('display','block');
      MWLIBclip.balloon.showGuest($(this)[0]); //吹き出し表示
    });
    $('.js-closebtn').on('click',function(){
      var $target = $(this).parents('.js-clip-guest-flag');
      $target.fadeOut();
    });
  }

  init();
})();


MWLIBclip.balloon = (function() {
  const tippyConfig = {
    theme: 'balloon',
    allowHTML: true,
    interactive: true,
    trigger: 'manual',
    maxWidth: "calc(100vw - (16px * 2))", // jsで位置調整する都合上cssでは定義できない
    placement: 'bottom',
    offset: [0, 12], // scaleでarrow::before/afterを拡大した分、位置調整
    popperOptions: {
      modifiers: [
        {
          name: 'preventOverflow',
          options: {
            boundary: 'viewport', // 画面端を超えないように強制
            padding: 16, // 画面端から最低Npxは離す
          },
        },
        {
          name: 'flip',
          options: {
            fallbackPlacements: ['top', 'bottom'], // 指定した placement で入らない場合に試す位置の順序
          },
        }
      ],
    },

    onMount(instance) {
      // 委譲用のハンドラをインスタンスに保持（remove時と同じ参照にするため）
      instance._handleDelegateClick = (event) => {
        // closestにより、要素内のアイコンなどがクリックされても正しく判定
        if (event.target.closest('.js-balloon-close')) {
          instance.hide();
        }
      };
      instance.popper.addEventListener('click', instance._handleDelegateClick);
    },

    onHide(instance) {
      // 非表示時にリスナーを解除
      if(instance._handleDelegateClick) {
        instance.popper.removeEventListener('click', instance._handleDelegateClick);
        delete instance._handleDelegateClick;
      }
    }
  };
  
  const getOrCreateInstance = (targetElem) => {
    if (!targetElem._tippy) {
      tippy(targetElem, tippyConfig);
    }
    return targetElem._tippy;
  };

  const show = (targetElem, templateId, placement = 'bottom') => {
    const instance = getOrCreateInstance(targetElem)
    if (instance) {
      const template = document.getElementById(templateId);
      instance.setContent(template.innerHTML);
      instance.setProps({placement: placement})
      instance.show();
    }
  }

  const showAdd = (targetElem) => {
    show(targetElem, 'clip-balloon-add-template');
  };

  const showDelete = (targetElem) => {
    show(targetElem, 'clip-balloon-delete-template');
  };

  const showAddFollow = (targetElem) => {
    show(targetElem, 'clip-balloon-add-follow-template', 'bottom-end');
  };

  const showDeleteFollow = (targetElem) => {
    show(targetElem, 'clip-balloon-delete-follow-template', 'bottom-end');
  };

  const showGuest = (targetElem) => {
    show(targetElem, 'clip-balloon-guest-template', 'bottom');
  };

  // 外部公開
  return {
    showAdd: showAdd,
    showDelete: showDelete,
    showAddFollow: showAddFollow,
    showDeleteFollow: showDeleteFollow,
    showGuest: showGuest,
  };
})();

})(jQuery);

</script>



